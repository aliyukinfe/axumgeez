<Window x:Class="AxumGeez.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="አክሱም ግዕዝ"
        Width="520"
        Height="420"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource LightSurface}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="አክሱም ግዕዝ"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrandBlack}"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource BrandWhite}"
                BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22"
                Margin="0,22,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Status" Foreground="{StaticResource BrandBlack}" FontWeight="SemiBold"/>
                <TextBlock x:Name="StatusText" Grid.Row="1" FontSize="28" FontWeight="Bold" Margin="0,6,0,18"/>

                <TextBlock x:Name="ModeText" Grid.Row="2" FontSize="18" Foreground="{StaticResource BrandBlack}" Margin="0,0,0,8"/>
                <TextBlock x:Name="FontNameText" Grid.Row="3" FontSize="18" Foreground="{StaticResource BrandBlack}" Margin="0,0,0,8"/>
                <TextBlock x:Name="ShortcutText" Grid.Row="4" FontSize="18" Foreground="#52606D" Margin="0,0,0,8"/>
                <TextBlock x:Name="LicenseText" Grid.Row="5" FontSize="14" Foreground="#52606D" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Settings" Click="OpenSettings"/>
        </StackPanel>
    </Grid>
</Window>
