<Window x:Class="AxumGeez.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="620"
        Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource LightSurface}">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="አክሱም ግዕዝ" FontSize="30" FontWeight="Bold" Foreground="{StaticResource BrandBlack}"/>
            <TextBlock Text="Settings" Foreground="#52606D" Margin="0,4,0,18"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="General" Padding="14" Margin="0,0,0,14" BorderBrush="{StaticResource BrandBorder}">
                    <StackPanel>
                        <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows"/>
                        <TextBlock Text="License server URL" Margin="0,14,0,0"/>
                        <TextBox x:Name="LicenseServerUrlTextBox"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Typing" Padding="14" Margin="0,0,0,14" BorderBrush="{StaticResource BrandBorder}">
                    <StackPanel>
                        <CheckBox x:Name="TypingSoundCheckBox" Content="Play typing sound"/>
                        <CheckBox x:Name="ConvertPunctuationCheckBox" Content="Convert punctuation"/>
                        <CheckBox x:Name="EthiopicNumeralsCheckBox" Content="Use Ethiopic numerals"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Fonts" Padding="14" Margin="0,0,0,14" BorderBrush="{StaticResource BrandBorder}">
                    <StackPanel>
                        <ComboBox x:Name="FontComboBox" Height="34" SelectionChanged="FontChanged"/>
                        <Border Background="{StaticResource BrandWhite}" BorderBrush="{StaticResource BrandBorder}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <TextBlock x:Name="FontPreviewText"
                                       Text="አክሱም ግዕዝ&#x0a;ሰላም ኢትዮጵያ&#x0a;ፊደል መጻፊያ"
                                       FontSize="24"
                                       LineHeight="38"
                                       Foreground="{StaticResource BrandBlack}"/>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Shortcuts" Padding="14" Margin="0,0,0,14" BorderBrush="{StaticResource BrandBorder}">
                    <StackPanel>
                        <TextBlock Text="Primary toggle"/>
                        <TextBox x:Name="ShortcutTextBox"/>
                        <TextBlock Text="Alternate toggle"/>
                        <TextBox x:Name="AlternateShortcutTextBox"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Appearance" Padding="14" Margin="0,0,0,14" BorderBrush="{StaticResource BrandBorder}">
                    <StackPanel>
                        <TextBlock Text="Theme"/>
                        <ComboBox x:Name="ThemeComboBox" Height="34">
                            <ComboBoxItem Content="System"/>
                            <ComboBoxItem Content="Light"/>
                            <ComboBoxItem Content="Dark"/>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="About" Padding="14" BorderBrush="{StaticResource BrandBorder}">
                    <TextBlock Text="Axum Geez types Unicode Amharic/Geez globally. Fonts are used only inside Axum Geez previews and copied rich text; Word, Excel, browsers, and websites control their own document fonts."
                               TextWrapping="Wrap"
                               Foreground="#52606D"/>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Background="{StaticResource DarkSurface}" Click="Cancel"/>
            <Button Content="Save" Click="Save"/>
        </StackPanel>
    </Grid>
</Window>
