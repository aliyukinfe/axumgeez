<Application x:Class="AxumGeez.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <Color x:Key="PrimaryBlueColor">#0B5CFF</Color>
        <Color x:Key="DeepBlueColor">#003B9E</Color>
        <Color x:Key="BlackColor">#05070A</Color>
        <Color x:Key="DarkSurfaceColor">#101418</Color>
        <Color x:Key="WhiteColor">#FFFFFF</Color>
        <Color x:Key="LightSurfaceColor">#F6F8FB</Color>
        <Color x:Key="BorderColor">#DDE3EA</Color>

        <SolidColorBrush x:Key="PrimaryBlue" Color="{StaticResource PrimaryBlueColor}"/>
        <SolidColorBrush x:Key="DeepBlue" Color="{StaticResource DeepBlueColor}"/>
        <SolidColorBrush x:Key="BrandBlack" Color="{StaticResource BlackColor}"/>
        <SolidColorBrush x:Key="DarkSurface" Color="{StaticResource DarkSurfaceColor}"/>
        <SolidColorBrush x:Key="BrandWhite" Color="{StaticResource WhiteColor}"/>
        <SolidColorBrush x:Key="LightSurface" Color="{StaticResource LightSurfaceColor}"/>
        <SolidColorBrush x:Key="BrandBorder" Color="{StaticResource BorderColor}"/>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="{StaticResource BrandWhite}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,8,0,12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBorder}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,8,0,12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBorder}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,7"/>
            <Setter Property="Foreground" Value="{StaticResource BrandBlack}"/>
        </Style>
    </Application.Resources>
</Application>
