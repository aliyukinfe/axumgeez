<Window x:Class="AxumGeez.App.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="260"
        Height="54"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <Border Background="{StaticResource DarkSurface}" CornerRadius="8" Padding="14" Opacity="0.97">
        <TextBlock x:Name="MessageText" Foreground="{StaticResource BrandWhite}" FontWeight="SemiBold" VerticalAlignment="Center"/>
    </Border>
</Window>
